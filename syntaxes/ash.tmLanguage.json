{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ash",
  "scopeName": "source.ash",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.double-slash.ash", "match": "//.*$" }]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.ash", "match": "\\b(if|else|while|for|in|return|try|catch)\\b" },
        { "name": "keyword.declaration.ash", "match": "\\b(let|fn)\\b" },
        { "name": "support.function.builtin.ash", "match": "\\bprint\\b" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ash",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "name": "constant.character.escape.ash", "match": "\\\\." }]
    },
    "numbers": {
      "name": "constant.numeric.ash",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "functions": {
      "patterns": [
        {
          "comment": "function definition name",
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": { "1": { "name": "entity.name.function.ash" } }
        },
        {
          "comment": "function call name",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.call.ash"
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.ash", "match": "==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.assignment.ash", "match": "=" },
        { "name": "keyword.operator.arithmetic.ash", "match": "\\+|\\-|\\*|/|%" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.terminator.ash", "match": ";" },
        { "name": "punctuation.separator.comma.ash", "match": "," },
        { "name": "punctuation.section.braces.ash", "match": "[{}]" },
        { "name": "punctuation.section.parens.ash", "match": "[()]" },
        { "name": "punctuation.section.brackets.ash", "match": "[\\[\\]]" }
      ]
    }
  }
}
